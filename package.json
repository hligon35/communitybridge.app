    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "nativewind": "^4.2.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
