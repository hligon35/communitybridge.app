{
  "name": "communitybridge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev:mobile": "npm run start:expo",
    "mobile:dev": "npm run start:expo",
    "mobile:prestart": "npm run prestart:expo",
    "prestart:expo": "node ./scripts/preflight-expo-start.js",
    "start:expo": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 NODE_OPTIONS=--max_old_space_size=8192 expo start",
    "start:expo:fast": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 NODE_OPTIONS=--max_old_space_size=8192 expo start --dev-client --lan",
    "update:mobile:all:internal": "npm run update:internal:arm",
    "update:mobile:all:testflight-internal": "npm run update:testflight-internal:arm",
    "update:mobile:all:preview": "npm run update:preview:arm",
    "update:mobile:all:production": "npm run update:production:arm",
    "mobile:update:all:internal": "npm run update:internal:arm",
    "mobile:update:all:testflight-internal": "npm run update:testflight-internal:arm",
    "mobile:update:all:preview": "npm run update:preview:arm",
    "mobile:update:all:production": "npm run update:production:arm",
    "build:mobile:android:internal": "npm run build:android:internal",
    "build:mobile:android:interactive": "npm run build:android:internal:interactive",
    "build:mobile:android:play-internal": "npm run build:android:preview",
    "build:mobile:android:play-production": "npm run build:android:production",
    "mobile:build:android:internal": "npm run build:android:internal",
    "mobile:build:android:interactive": "npm run build:android:internal:interactive",
    "mobile:build:android:play-internal": "npm run build:android:preview",
    "mobile:build:android:play-production": "npm run build:android:production",
    "build:mobile:ios:internal": "npm run build:ios:internal",
    "build:mobile:ios:internal:interactive": "npm run build:ios:internal:interactive",
    "build:mobile:ios:testflight-internal": "npm run build:ios:testflight-internal",
    "build:mobile:ios:testflight-internal:interactive": "npm run build:ios:testflight-internal:interactive",
    "build:mobile:ios:preview": "npm run build:ios:preview",
    "build:mobile:ios:production": "npm run build:ios:production",
    "mobile:build:ios:internal": "npm run build:ios:internal",
    "mobile:build:ios:internal:interactive": "npm run build:ios:internal:interactive",
    "mobile:build:ios:testflight-internal": "npm run build:ios:testflight-internal",
    "mobile:build:ios:testflight-internal:interactive": "npm run build:ios:testflight-internal:interactive",
    "mobile:build:ios:preview": "npm run build:ios:preview",
    "mobile:build:ios:production": "npm run build:ios:production",
    "submit:mobile:android:internal": "npm run submit:android:internal",
    "submit:mobile:android:play-internal": "npm run submit:android:preview",
    "submit:mobile:android:play-production": "npm run submit:android:production",
    "submit:mobile:ios:testflight-internal": "npm run submit:ios:testflight-internal",
    "submit:mobile:ios:production": "npm run submit:ios:production",
    "mobile:submit:android:internal": "npm run submit:android:internal",
    "mobile:submit:android:play-internal": "npm run submit:android:preview",
    "mobile:submit:android:play-production": "npm run submit:android:production",
    "mobile:submit:ios:testflight-internal": "npm run submit:ios:testflight-internal",
    "mobile:submit:ios:production": "npm run submit:ios:production",

    "android": "expo run:android",
    "android:run": "npm run android",
    "run:android": "npm run android",
    "update:mobile:android:preview": "npm run update:android:preview:arm",
    "update:mobile:android:production": "npm run update:android:production:arm",
    "android:update:preview": "npm run update:android:preview:arm",
    "android:update:production": "npm run update:android:production:arm",
    "android:update:play-internal": "npm run update:android:preview:arm",
    "android:update:play-production": "npm run update:android:production:arm",
    "update:android:preview:arm": "node ./scripts/eas-update.js --channel preview --platform android",
    "update:android:production:arm": "node ./scripts/eas-update.js --channel production --platform android",
    "build:android:internal": "eas build -p android --profile internal --non-interactive",
    "build:android:internal:interactive": "eas build -p android --profile internal",
    "build:android:preview": "eas build -p android --profile preview --non-interactive",
    "build:android:production": "eas build -p android --profile production --non-interactive",
    "android:build:internal": "npm run build:android:internal",
    "android:build:internal:interactive": "npm run build:android:internal:interactive",
    "android:build:preview": "npm run build:android:preview",
    "android:build:production": "npm run build:android:production",
    "android:build:play-internal": "npm run build:android:preview",
    "android:build:play-production": "npm run build:android:production",
    "submit:android:internal": "eas submit -p android --latest --non-interactive --key ./google-play-service-account.json",
    "submit:android:preview": "eas submit -p android --profile preview --latest --non-interactive --key ./google-play-service-account.json",
    "submit:android:production": "eas submit -p android --profile production --latest --non-interactive --key ./google-play-service-account.json",
    "android:submit:internal": "npm run submit:android:internal",
    "android:submit:preview": "npm run submit:android:preview",
    "android:submit:production": "npm run submit:android:production",
    "android:submit:play-internal": "npm run submit:android:preview",
    "android:submit:play-production": "npm run submit:android:production",

    "ios": "expo run:ios",
    "ios:run": "npm run ios",
    "run:ios": "npm run ios",
    "update:mobile:ios:internal": "npm run update:ios:internal:arm",
    "update:mobile:ios:testflight-internal": "npm run update:ios:testflight-internal:arm",
    "update:mobile:ios:preview": "npm run update:ios:preview:arm",
    "update:mobile:ios:production": "npm run update:ios:production:arm",
    "ios:update:internal": "npm run update:ios:internal:arm",
    "ios:update:testflight-internal": "npm run update:ios:testflight-internal:arm",
    "ios:update:preview": "npm run update:ios:preview:arm",
    "ios:update:production": "npm run update:ios:production:arm",
    "update:ios:internal:arm": "node ./scripts/eas-update.js --channel internal --platform ios",
    "update:ios:testflight-internal:arm": "node ./scripts/eas-update.js --channel testflight-internal --platform ios",
    "update:ios:preview:arm": "node ./scripts/eas-update.js --channel preview --platform ios",
    "update:ios:production:arm": "node ./scripts/eas-update.js --channel production --platform ios",
    "build:ios:internal": "eas build -p ios --profile internal --non-interactive",
    "build:ios:internal:interactive": "eas build -p ios --profile internal",
    "build:ios:testflight-internal": "eas build -p ios --profile testflight-internal --non-interactive",
    "build:ios:testflight-internal:interactive": "eas build -p ios --profile testflight-internal",
    "build:ios:preview": "eas build -p ios --profile preview --non-interactive",
    "build:ios:production": "eas build -p ios --profile production --non-interactive",
    "ios:build:internal": "npm run build:ios:internal",
    "ios:build:internal:interactive": "npm run build:ios:internal:interactive",
    "ios:build:testflight-internal": "npm run build:ios:testflight-internal",
    "ios:build:testflight-internal:interactive": "npm run build:ios:testflight-internal:interactive",
    "ios:build:preview": "npm run build:ios:preview",
    "ios:build:production": "npm run build:ios:production",
    "submit:ios:testflight-internal": "eas submit -p ios --profile testflight-internal --latest --non-interactive",
    "submit:ios:production": "eas submit -p ios --profile production --latest --non-interactive",
    "ios:submit:testflight-internal": "npm run submit:ios:testflight-internal",
    "ios:submit:production": "npm run submit:ios:production",

    "dev:web": "npm run web",
    "web:dev": "npm run web",
    "web": "node ./scripts/start-web-dev.js",
    "gcp-build": "node ./scripts/build-web.js",
    "build:web": "node ./scripts/build-web.js",
    "web:build": "npm run build:web",
    "web:deploy": "npm run deploy:firebase",
    "deploy:firebase": "npm run build:web && firebase deploy --only hosting",

    "dev:api": "npm run api:server",
    "start": "node ./scripts/start-server.js",
    "api:server": "cross-env PORT=3005 node ./scripts/api-server.js",
    "api:mock": "cross-env PORT=3006 node ./scripts/api-mock.js",

    "lint": "eslint --quiet --no-error-on-unmatched-pattern App.js screens/**/*.js src/**/*.js scripts/**/*.js tests/**/*.js app.config.js babel.config.js metro.config.js postcss.config.js tailwind.config.js eslint.config.js --ignore-pattern archive/** --ignore-pattern functions/** --ignore-pattern public/** --ignore-pattern src/seed/** --ignore-pattern scripts/api-mock.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:unit": "node --test tests/*.test.js",
    "dev-clear-server": "node ./scripts/dev-clear-server.js",
    "maintenance:dev-clear-server": "npm run dev-clear-server",
    "smoke": "node ./scripts/smoke-e2e.js",
    "test:smoke": "npm run smoke",
    "smoke:mock": "cross-env BB_BASE_URL=http://127.0.0.1:3006 node ./scripts/smoke-e2e.js",
    "test:smoke:mock": "npm run smoke:mock",
    "smoke:server": "cross-env BB_BASE_URL=http://127.0.0.1:3005 node ./scripts/smoke-e2e.js",
    "test:smoke:server": "npm run smoke:server",
    "smoke:therapy": "node ./scripts/smoke-therapy-session.js",
    "test:smoke:therapy": "npm run smoke:therapy",
    "smoke:therapy:mock": "cross-env BB_BASE_URL=http://127.0.0.1:3006 node ./scripts/smoke-therapy-session.js",
    "test:smoke:therapy:mock": "npm run smoke:therapy:mock",
    "smoke:therapy:server": "cross-env BB_BASE_URL=http://127.0.0.1:3005 node ./scripts/smoke-therapy-session.js",
    "test:smoke:therapy:server": "npm run smoke:therapy:server",
    "validate:full": "node ./scripts/validate-full-stack.js",

    "generate:icons": "node ./scripts/generate_icon_sets.js",
    "check:secrets": "node ./scripts/check-secrets.js",
    "db:dups": "node ./scripts/find-duplicate-users.js",
    "cleanup:retain-dev-appreview": "node ./scripts/cleanup-retain-dev-and-appreview.js",
    "cleanup:retain-dev-appreview:dry": "node ./scripts/cleanup-retain-dev-and-appreview.js --dry",
    "db:migrate:pg": "node ./scripts/migrate-sqlite-to-postgres.js",
    "seed:tenant-directory": "node ./scripts/seed-tenant-directory.js",
    "seed:tenant-directory:dry": "node ./scripts/seed-tenant-directory.js --dry",
    "seed:test-users": "node ./scripts/seed-test-users.js",
    "seed:test-users:dry": "node ./scripts/seed-test-users.js --dry",
    "role:grant": "node ./scripts/grant-admin-role.js",
    "role:grant:dry": "node ./scripts/grant-admin-role.js --dry",
    "dev:user:sync": "node ./scripts/sync-dev-account.js",
    "dev:user:sync:dry": "node ./scripts/sync-dev-account.js --dry",
    "update:internal:arm": "node ./scripts/eas-update.js --channel internal",
    "update:testflight-internal:arm": "node ./scripts/eas-update.js --channel testflight-internal",
    "update:preview:arm": "node ./scripts/eas-update.js --channel preview",
    "update:production:arm": "node ./scripts/eas-update.js --channel production",
    "cloudrun:secrets": "powershell -ExecutionPolicy Bypass -File ./scripts/create-cloudrun-secrets.ps1 -FromFile ./env/cloudrun.env",
    "cloudrun:update": "gcloud run services update communitybridge --region us-central1 --project communitybridge-26apr --env-vars-file tmp/cloudrun-nonsecrets.env.yaml --update-secrets \"CB_DATABASE_URL=cb-database-url:latest,BB_DATABASE_URL=bb-database-url:latest,CB_JWT_SECRET=cb-jwt-secret:latest,BB_JWT_SECRET=bb-jwt-secret:latest,CB_SMTP_URL=cb-smtp-url:latest,BB_SMTP_URL=bb-smtp-url:latest,CB_TWILIO_AUTH_TOKEN=cb-twilio-token:latest,BB_TWILIO_AUTH_TOKEN=bb-twilio-token:latest,CB_ADMIN_PASSWORD=cb-admin-password:latest,BB_ADMIN_PASSWORD=bb-admin-password:latest\"",
    "cloudrun:sync": "npm run cloudrun:secrets ; npm run cloudrun:update"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^6.5.7",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@sentry/react-native": "~7.2.0",
    "axios": "^1.13.2",
    "babel-preset-expo": "~54.0.9",
